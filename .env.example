# ===========================================
# Google Maps Platform 環境変数
# ===========================================
# 1. このファイルを .env.local にコピー
# 2. your_api_key_here を実際の API キーに置き換え
# 3. .env.local は Git に含めない（.gitignore 済み）

# サーバーサイド用（Next.js API Routes から使用）
# 用途: Geocoding API / Directions API / Places API
# 制限: 「API の制限」で上記 API のみ許可
GOOGLE_MAPS_API_KEY=your_api_key_here

# ブラウザ用（Maps JavaScript API）
# 用途: 地図表示（Step 4 で使用）
# 制限: HTTP リファラー → http://localhost:3000/*
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here
