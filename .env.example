# ===========================================
# Google Maps Platform 環境変数
# ===========================================

# サーバーサイド用（Next.js API Routes）
# Geocoding API / Directions API / Places API
GOOGLE_MAPS_API_KEY=your_api_key_here

# ブラウザ用（Maps JavaScript API）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# ===========================================
# リファラー制限（ブラウザ用キー）
# ===========================================
# ローカル:     http://localhost:3000/*
# Vercel本番:   https://your-project.vercel.app/*
#               https://*.vercel.app/*
